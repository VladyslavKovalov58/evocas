tDeposit\":\"Сделай свой первый депозит\",\"columns\":{\"time\":\"Время\",\"amount\":\"Сумма\",\"type\":\"Тип\",\"method\":\"Метод\",\"status\":\"Статус\",\"info\":\"Инфо\"},\"copyText\":{\"successDescription\":\"Текст успешно скопирован\",\"errorDescription\":\"Ошибка при копировании\",\"copyInfo\":\"Скопировать инфо\"},\"deposit\":\"Депозит\",\"withdraw\":\"Вывод\",\"success\":\"Успешно\",\"error\":\"Ошибка\",\"inProcess\":\"В обработке\",\"unknownStatus\":\"Неизвестный статус\",\"cancel\":\"Отменить\",\"cancelTransaction\":\"Отменить транзакцию\",\"tooManyAttempts\":\"Слишком много запросов. Пожалуйста, попробуйте позже.\",\"cantDecline\":\"Транзакция уже обработана и не может быть отменена.\",\"cancelWithdraw\":\"Отменить вывод средств?\",\"assetsReturn\":\"Средства будут возвращены на игровой баланс, и вы сможете продолжить игру\",\"cancelButton\":\"Отменить вывод\",\"proceedButton\":\"Продолжить вывод\"},\"kyc\":{\"idFront\":\"Паспорт (лицевая сторона)\",\"idBack\":\"Паспорт (обратная сторона)\",\"addressConfirm\":\"Подтверждение адреса\",\"selfieWithID\":\"Селфи с паспортом\",\"selfieWithIdAndA4\":\"Селфи с паспортом и A4\",\"paymentProve\":\"Подтверждение платежа\",\"unknownDocument\":\"Неизвестный документ\",\"approved\":\"Принят\",\"review\":\"На проверке\",\"declined\":\"Отклонено\",\"press\":\"Нажмите\",\"uploadRules\":\"чтобы загрузить файл в формате .png, .jpg, .pdf. Максимальный размер 7Мб\",\"reason\":\"Причина\",\"button\":{\"uploadAgain\":\"Загрузить снова\"},\"toast\":{\"title\":\"Ошибка загрузки\",\"wrongSize\":\"Размер файла больше 7МБ\",\"wrongFormat\":\"Неверный формат файла\"}}},\"shop\":{\"earnLoyalty\":\"Заработать ключи\",\"header\":{\"bonusShop\":\"Магазин бонусов\",\"buyItems\":\"Ключи остаются после игры. \u003cbr\u003e\u003c/br\u003e Трать их на бонусы и мои шкатулки с подарками\",\"youHave\":\"У тебя:\",\"superPrizesTitle\":\"Суперпризы\",\"superPrizesText\":\"От приятных мелочей до вещей, которые меняют планы\",\"back\":\"Назад\",\"takeLoyalty\":\"Получить ключи\"},\"tooltip\":{\"loyaltyInfo\":\"Когда ты играешь, \u003ccolorYellow\u003eключи\u003c/colorYellow\u003e собираются сами.\",\"wagerFormula\":\"Каждые \u003ccolorGreen\u003e2 000 ₽\u003c/colorGreen\u003e ставок = 1 \u003ccolorYellow\u003eключ\u003c/colorYellow\u003e\"},\"lootboxes\":{\"title\":\"Шкатулки\",\"maxPrize\":\"Макс. приз:\"},\"freeSpins\":{\"title\":\"Фриспины\",\"betAmount\":\"Размер ставки\",\"spinAmount\":\"Количество спинов\"},\"FAQ\":{\"title\":\"FAQ\",\"Q1\":\"Как зарабатывать ключи?\",\"A1\":\"Ключи начисляются за активную игру. За каждые 2 000 рублей, поставленные в слотах или других играх на платформе, ты получаешь 1 ключ. Чем больше играешь — тем больше ключей накапливаешь. Всё просто.\",\"Q2\":\"На что я могу потратить ключи?\",\"A2\":\"Ключи можно обменять на лутбоксы — внутри них тебя ждут бонусы: деньги на бонусный баланс или фриспины в самых популярных слотах. Ты сам выбираешь, что тебе интереснее — больше денег или вращений. А также в каждом из лутбоксов есть шанс получить один из наших супер призов.\",\"Q3\":\"Есть ли ограничения на количество ключей?\",\"A3\":\"Да, есть ограничение на количество ключей, которое можно получить. Оно зависит от суммы депозитов, сделанных с 10 февраля 2026 года — даты запуска системы ключей. Формула расчёта лимита: Максимум ключей = Сумма депозитов с 10.02.2026 × 10 Пример: если с 10 февраля пользователь внёс депозитов на 5 000 ₽, он сможет заработать не более 50 ключей. Важно: ограничений на хранение ключей нет — все полученные ключи остаются на аккаунте без срока действия и могут быть использованы в любое время.\"},\"notEnoughLoyaltyModal\":{\"title\":\"Не хватает ключей?\",\"description\":\"Так бывает. Они появятся по ходу игры\",\"everyLoyalty\":\"Делай ставки в играх \u003cbr\u003e\u003c/br\u003e Каждые \u003ccolorGreen\u003e2000 ₽\u003c/colorGreen\u003e = \u003ccolorYellow\u003e1 ключ\u003c/colorYellow\u003e\",\"dailyLogin\":\"Я дам тебе их просто так. Если ты появишься завтра\"},\"verificationMissionModal\":{\"title\":\"Выполняй миссии \u003cbr\u003e\u003c/br\u003eи забирай Ключи!\",\"activate\":\"Активировать\"},\"confirmFreespinModal\":{\"title\":\"Открыть фриспины?\",\"description\":\"Уверен что хочешь открыть эти фриспины?\",\"cta\":\"открыть за\",\"cancel\":\"Отмена\"},\"confirmLootboxModal\":{\"claimPrize\":\"Забрать приз\"},\"error\":{\"title\":\"Ошибка\",\"description\":\"Что-то пошло не так, попробуйте ещё раз\"}},\"bonus\":{\"active\":\"Активные\",\"available\":\"Доступные\",\"activate\":\"Активировать\",\"cancel\":\"Отменить\",\"bonusAmount\":\"Сумма бонуса\",\"freeSpinsUsed\":\"Фриспинов использовано\",\"playProgress\":\"Прогресс отыгрыша\",\"cashback\":\"Кешбэк\",\"activeCashback\":\"Распределение прошло, забирай\",\"notActiveCashback\":\"Подарочек за твои старания\",\"yourCashback\":\"Твой кешбэк\",\"timeToCashback\":\"Распределение через\",\"future\":\"Будущие\",\"fsGame\":{\"chooseFsGame\":\"Выбери игру\",\"error\":\"Ошибка\",\"activationError\":\"Ошибка активации\"},\"noBonuses\":{\"title\":\"Бонусы закончились?\",\"comeToTelegram\":\"Заходи в Телеграм\",\"iHideBonuses\":\"Самое интересное я прячу там\",\"telegramLink\":\"В Телеграм\"},\"notActive\":{\"title\":\"Бонусы\",\"cardDescription\":\"Бонус на {number}й депозит\",\"link\":\"Получить бонус\",\"whatIHave\":\"Что у меня есть\",\"notForAll\":\"Не всё сразу. И не для всех\"},\"infoModal\":{\"bonus\":\"Бонус\",\"progressiveBonus\":\"Прогрессивный бонус\",\"progressiveBonusInfo\":\"Чем больше депозит - тем больше бонус\",\"fs\":\"ФС\",\"freeSpins\":\"Фри спины\",\"availableFreeSpins\":\"Доступные фри спины\",\"to\":\"до\",\"realBalance\":\"Реальный баланс\",\"realAndBonusBalance\":\"Реальный + бонусный баланс\",\"deposit\":\"Депозит\",\"minDeposit\":\"Минимальный депозит\",\"cashback\":\"Кешбэк\",\"minCashback\":\"Минимальный кешбэк\",\"maxCashback\":\"Макс кешбэк\",\"registration\":\"Регистрация\",\"noDeposit\":\"Бездеп\",\"bonusType\":\"Тип бонуса\",\"bonusSize\":